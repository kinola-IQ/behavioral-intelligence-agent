import json

# Read the single-line JSON file
with open("path to input file", "r", encoding="utf-8") as f:
    data = json.load(f)

# Write it in a structured (pretty-printed) format
with open("path to output file", "w", encoding="utf-8") as f:
    json.dump(data, f, indent=4, ensure_ascii=False)

print("JSON has been formatted successfully.")
